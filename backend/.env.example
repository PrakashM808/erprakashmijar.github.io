# PostgreSQL Database (add from Railway dashboard)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ══════════════════════════════════════════════════════════
# PM::OFFSEC Backend — Environment Variables
# Copy this to .env and fill in your values
# ══════════════════════════════════════════════════════════

# ── REQUIRED ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ── SENDGRID (email alerts — sendgrid.com, free 100/day) ──
SENDGRID_API_KEY=SG.your-key-here
ALERT_FROM_EMAIL=alerts@erprakashmijar.com
ALERT_FROM_NAME=PM::OFFSEC Security Dashboard

# ── STRIPE (dashboard.stripe.com) ─────────────────────────
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_STARTER_PRICE_ID=price_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_ENTERPRISE_PRICE_ID=price_xxx

# ── LEMON SQUEEZY (app.lemonsqueezy.com) ──────────────────
LEMONSQUEEZY_API_KEY=your-key
LEMONSQUEEZY_STORE_ID=your-store-id
LEMONSQUEEZY_WEBHOOK_SECRET=your-secret
LS_STARTER_VARIANT_ID=your-id
LS_PRO_VARIANT_ID=your-id
LS_ENTERPRISE_VARIANT_ID=your-id

# ── APP ────────────────────────────────────────────────────
APP_URL=https://erprakashmijar.com
PORT=8000

# ── THREAT INTELLIGENCE (all free tiers) ──────────────────────
# Have I Been Pwned — haveibeenpwned.com/API/Key ($3.50/month)
HIBP_API_KEY=your-hibp-key

# AbuseIPDB — abuseipdb.com (free: 1000 checks/day)
ABUSEIPDB_API_KEY=your-abuseipdb-key

# VirusTotal — virustotal.com (free: 4 lookups/minute)
VIRUSTOTAL_API_KEY=your-virustotal-key

# Shodan — shodan.io (free: limited lookups)
SHODAN_API_KEY=your-shodan-key

# ── SIEM INTEGRATIONS ─────────────────────────────────────────
# Wazuh — your Wazuh manager URL
WAZUH_URL=https://your-wazuh-manager:55000
WAZUH_USER=wazuh
WAZUH_PASSWORD=your-wazuh-password

# Splunk — your Splunk instance
SPLUNK_URL=https://your-splunk:8089
SPLUNK_TOKEN=your-splunk-token
SPLUNK_HEC_URL=https://your-splunk:8088/services/collector
SPLUNK_HEC_TOKEN=your-hec-token
